.source-control-sidebar-host {
  background: #fafafa;
}

.source-control-sidebar {
  --scm-bg: #fafafa;
  --scm-bg-elev: #fafafa;
  --scm-bg-hover: var(--bg-h);
  --scm-bg-active: var(--bg-s);
  --scm-border: var(--border-subtle);
  --scm-text: var(--text-primary);
  --scm-text-dim: var(--text-tertiary);
  --scm-text-faint: var(--text-quaternary);
  --scm-accent: var(--accent-strong);
  --scm-green: #4ade80;
  --scm-yellow: #facc15;
  --scm-red: #f87171;
  --scm-blue: #60a5fa;
  --scm-radius: 6px;
  --scm-font:
    ui-sans-serif, -apple-system, 'Inter', 'SF Pro Text', 'PingFang SC', system-ui, sans-serif;
  display: flex;
  height: 100%;
  min-height: 0;
  width: 100%;
  flex-direction: column;
  background: var(--scm-bg);
  color: var(--scm-text);
  font-family: var(--scm-font);
  font-size: 13px;
  -webkit-font-smoothing: antialiased;
  overflow: hidden;
  user-select: none;
}

.source-control-empty-shell {
  display: flex;
  flex: 1;
  padding: 12px;
}

.source-control-setup-shell {
  padding: 0;
}

.source-control-setup-panel {
  display: flex;
  min-height: 0;
  width: 100%;
  flex: 1;
  flex-direction: column;
  overflow: hidden;
  border: 0;
  border-radius: 0;
  background: var(--scm-bg);
}

.source-control-setup-project-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  border-bottom: 1px solid var(--scm-border);
  padding: 16px 18px 12px;
  cursor: default;
}

.source-control-setup-project-name {
  color: var(--scm-text);
  font-size: 15px;
  font-weight: 600;
  letter-spacing: -0.01em;
}

.source-control-setup-chevron {
  width: 14px;
  height: 14px;
  color: var(--scm-text-dim);
  fill: none;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 1.5;
}

.source-control-setup-search-bar svg,
.source-control-setup-footnote svg {
  width: 13px;
  height: 13px;
  flex-shrink: 0;
  fill: none;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 1.5;
}

.source-control-setup-empty-state {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  align-items: center;
  padding: 72px 24px 0;
  text-align: center;
}

.source-control-setup-empty-icon {
  width: 48px;
  height: 48px;
  margin-bottom: 22px;
  color: var(--scm-text-dim);
  fill: none;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 1.75;
}

.source-control-setup-empty-icon .is-solid {
  fill: currentColor;
  stroke: none;
}

.source-control-setup-empty-icon .is-accent-ring {
  fill: #fafafa;
  stroke: #5b5fcf;
  stroke-width: 2;
}

.source-control-setup-empty-icon .is-accent-dot {
  fill: #5b5fcf;
  stroke: none;
}

.source-control-setup-empty-title {
  margin: 0 0 8px;
  color: var(--scm-text);
  font-size: 14.5px;
  font-weight: 600;
  letter-spacing: -0.01em;
}

.source-control-setup-empty-desc {
  margin: 0 0 28px;
  max-width: 220px;
  color: var(--scm-text-dim);
  font-size: 12.5px;
  line-height: 1.55;
}

.source-control-setup-error {
  width: 100%;
  max-width: 224px;
  margin: -14px 0 14px;
  border: 1px solid rgba(248, 113, 113, 0.22);
  border-radius: 6px;
  background: rgba(248, 113, 113, 0.08);
  padding: 8px 10px;
  color: #fecaca;
  font-size: 11.5px;
  line-height: 1.5;
  text-align: left;
}

.source-control-setup-actions {
  display: flex;
  width: 100%;
  max-width: 224px;
  flex-direction: column;
  gap: 8px;
}

.source-control-setup-btn {
  display: flex;
  width: 100%;
  height: 34px;
  align-items: center;
  justify-content: center;
  gap: 6px;
  border: none;
  border-radius: 6px;
  font-family: inherit;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: -0.005em;
  cursor: pointer;
  transition: none;
}

.source-control-setup-btn:disabled {
  cursor: default;
  opacity: 1;
}

.source-control-setup-btn-primary {
  background: var(--accent);
  box-shadow: 0 1px 0 rgba(255, 255, 255, 0.08) inset;
  color: var(--text-primary);
}

.source-control-setup-btn-primary:active:not(:disabled) {
  background: var(--accent);
}

.source-control-setup-btn-secondary {
  border: 1px solid var(--scm-border);
  background: transparent;
  color: var(--scm-text);
}

.source-control-setup-btn-secondary:hover:not(:disabled) {
  border-color: var(--scm-border);
  background: #fafafa;
  color: var(--text-primary);
}

@media (hover: hover) and (pointer: fine) {
  .source-control-setup-btn-primary:hover:not(:disabled) {
    background: var(--accent);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.08) inset;
  }
}

.source-control-setup-divider {
  width: 100%;
  max-width: 200px;
  height: 1px;
  margin: 36px 0 14px;
  background: var(--scm-border);
}

.source-control-setup-footnote {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  border: 0;
  background: transparent;
  padding: 0;
  color: var(--scm-text-dim);
  font-family: inherit;
  font-size: 12px;
  cursor: pointer;
  transition: color 0.12s ease;
}

.source-control-setup-footnote:hover {
  color: var(--scm-text);
}

.source-control-empty-card {
  width: 100%;
  border: 1px solid var(--scm-border);
  border-radius: var(--scm-radius);
  background: var(--scm-bg);
  padding: 12px;
}

.source-control-empty-card-inline {
  margin: 0 0 8px;
}

.source-control-empty-title,
.source-control-repo-name,
.source-control-branch-name {
  margin: 0;
  color: var(--scm-text);
}

.source-control-empty-title,
.source-control-repo-name {
  font-size: 13px;
  font-weight: 500;
}

.source-control-empty-text,
.source-control-file-dir,
.source-control-statusbar {
  color: var(--scm-text-faint);
}

.source-control-empty-text {
  margin: 6px 0 0;
  font-size: 11.5px;
  line-height: 1.6;
}

.source-control-repo,
.source-control-search,
.source-control-branch,
.source-control-nav {
  border-bottom: 1px solid var(--scm-border);
}

.source-control-repo,
.source-control-branch,
.source-control-statusbar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 12px;
}

.source-control-repo:hover,
.source-control-branch:hover {
  background: var(--scm-bg-hover);
}

.source-control-repo-copy,
.source-control-branch-copy {
  min-width: 0;
  flex: 1;
}

.source-control-repo-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.source-control-repo-name small {
  margin-left: 6px;
  color: var(--scm-text-dim);
  font-size: 13px;
  font-weight: 400;
}

.source-control-repo-chevron svg,
.source-control-search-box svg,
.source-control-branch-icon,
.source-control-nav-item svg,
.source-control-section-chevron,
.source-control-icon-btn svg,
.source-control-btn-icon svg {
  width: 14px;
  height: 14px;
  fill: none;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 2;
}

.source-control-toolbar {
  display: flex;
  align-items: center;
  gap: 6px;
  border-bottom: 1px solid var(--scm-border);
  padding: 7px 8px;
  background: #fafafa;
}

.source-control-toolbar-btn,
.source-control-toolbar-icon {
  border: 1px solid var(--scm-border);
  border-radius: var(--scm-radius);
  background: var(--scm-bg-elev);
  color: var(--scm-text-dim);
  font-family: inherit;
  font-size: 11.5px;
  font-weight: 500;
  cursor: pointer;
  transition:
    background 80ms linear,
    border-color 80ms linear,
    color 80ms linear;
}

.source-control-toolbar-btn {
  min-width: 0;
  flex: 1;
  padding: 5px 7px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.source-control-toolbar-btn:hover:not(:disabled),
.source-control-toolbar-icon:hover:not(:disabled) {
  border-color: rgba(255, 255, 255, 0.12);
  background: var(--scm-bg-hover);
  color: var(--scm-text);
}

.source-control-toolbar-btn.is-danger:hover:not(:disabled) {
  border-color: rgba(248, 113, 113, 0.3);
  color: #fecaca;
}

.source-control-toolbar-btn:disabled,
.source-control-toolbar-icon:disabled {
  cursor: default;
  opacity: 0.42;
}

.source-control-branch {
  cursor: pointer;
}

.source-control-branch-icon {
  color: var(--scm-text-dim);
  flex-shrink: 0;
}

.source-control-branch-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 12.5px;
}

.source-control-branch-sync {
  display: flex;
  gap: 6px;
  color: var(--scm-text-dim);
  font-size: 11px;
  font-variant-numeric: tabular-nums;
}

.source-control-branch-sync span {
  display: inline-flex;
  align-items: center;
  gap: 2px;
}

.source-control-nav {
  padding: 6px 6px 10px;
}

.source-control-nav-item {
  display: flex;
  width: 100%;
  align-items: center;
  gap: 10px;
  border: 0;
  border-radius: var(--scm-radius);
  background: transparent;
  padding: 6px 8px;
  color: var(--scm-text-dim);
  font: inherit;
  cursor: pointer;
  text-align: left;
  transition:
    background 80ms linear,
    color 80ms linear;
}

.source-control-nav-item + .source-control-nav-item {
  margin-top: 2px;
}

.source-control-nav-item.is-inactive:hover {
  background: var(--scm-bg-hover);
  color: var(--scm-text);
}

.source-control-nav-item.is-active {
  background: var(--scm-bg-active);
  color: var(--scm-text);
}

.source-control-nav-label {
  flex: 1;
}

.source-control-nav-count,
.source-control-section-count {
  color: var(--scm-text-faint);
  font-size: 11px;
  font-variant-numeric: tabular-nums;
}

.source-control-section-count {
  margin-left: auto;
  letter-spacing: 0;
  text-transform: none;
}

.source-control-scroll {
  flex: 1;
  overflow-x: hidden;
  overflow-y: auto;
}

.source-control-scroll::-webkit-scrollbar {
  width: 8px;
}

.source-control-scroll::-webkit-scrollbar-thumb {
  border-radius: 4px;
  background: color-mix(in srgb, var(--shell-divider) 90%, transparent);
}

.source-control-scroll::-webkit-scrollbar-thumb:hover {
  background: color-mix(in srgb, var(--shell-divider) 100%, transparent);
}

.source-control-section {
  padding: 8px 6px;
}

.source-control-section + .source-control-section {
  border-top: 1px solid var(--scm-border);
}

.source-control-section-header {
  display: flex;
  width: 100%;
  align-items: center;
  gap: 6px;
  border: 0;
  background: transparent;
  padding: 4px 8px 6px;
  color: var(--scm-text-faint);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  text-align: left;
}

.source-control-section-chevron {
  color: var(--scm-text-faint);
  width: 10px;
  height: 10px;
  transition: transform 0.15s ease;
  stroke-width: 2.5;
}

.source-control-section.is-collapsed .source-control-section-chevron {
  transform: rotate(-90deg);
}

.source-control-section.is-collapsed .source-control-file-list {
  display: none;
}

.source-control-info-panel {
  margin: 10px;
  border: 1px solid var(--scm-border);
  border-radius: 8px;
  background: var(--scm-bg-elev);
  padding: 12px;
}

.source-control-info-eyebrow {
  margin: 0 0 8px;
  color: var(--scm-text-faint);
  font-size: 10.5px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.source-control-info-title {
  margin: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  color: var(--scm-text);
  font-size: 13px;
  font-weight: 600;
  line-height: 1.45;
}

.source-control-info-text,
.source-control-info-note {
  margin: 7px 0 0;
  color: var(--scm-text-dim);
  font-size: 12px;
  line-height: 1.55;
}

.source-control-info-note {
  color: var(--scm-text-faint);
}

.source-control-history-panel {
  margin: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  overflow: hidden;
  padding: 0;
}

.source-control-history-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 10px;
  padding: 12px 16px 4px;
}

.source-control-history-heading,
.source-control-history-summary {
  margin: 0;
}

.source-control-history-header-actions {
  display: inline-flex;
  min-width: 0;
  flex: 0 0 auto;
  align-items: center;
  justify-content: flex-end;
  gap: 8px;
  flex-wrap: nowrap;
  white-space: nowrap;
}

.source-control-history-heading {
  color: var(--scm-text-faint);
  font-size: 10.5px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.source-control-history-summary {
  color: var(--scm-text-faint);
  font-size: 12px;
  font-variant-numeric: tabular-nums;
  line-height: 1.45;
  white-space: nowrap;
}

.source-control-history-refresh {
  display: inline-flex;
  flex: 0 0 auto;
  width: 24px;
  height: 24px;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 999px;
  background: transparent;
  color: var(--scm-text-faint);
  padding: 0;
  line-height: 0;
  transition:
    background 0.14s cubic-bezier(0.23, 1, 0.32, 1),
    color 0.14s cubic-bezier(0.23, 1, 0.32, 1);
}

.source-control-history-refresh:hover:not(:disabled) {
  background: color-mix(in srgb, var(--scm-bg-hover) 82%, transparent);
  color: var(--scm-text);
}

.source-control-history-refresh:disabled {
  opacity: 0.42;
  cursor: default;
}

.source-control-history-refresh svg {
  width: 13px;
  height: 13px;
  stroke-width: 2;
}

.source-control-history-note {
  margin: 0;
  padding: 6px 16px 10px;
}

.source-control-history-timeline {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 4px 16px 10px;
}

.source-control-history-timeline::before {
  content: '';
  position: absolute;
  left: 27px;
  top: 12px;
  bottom: 12px;
  width: 1px;
  background: var(--scm-border);
}

.source-control-history-item {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 24px minmax(0, 1fr) auto;
  align-items: start;
  gap: 10px;
  padding: 6px 8px 6px 0;
  border-radius: calc(var(--scm-radius) + 2px);
  transition: background 0.16s cubic-bezier(0.23, 1, 0.32, 1);
}

.source-control-history-item:hover {
  background: color-mix(in srgb, var(--scm-bg-hover) 72%, transparent);
}

.source-control-history-node {
  display: grid;
  width: 24px;
  height: auto;
  place-items: center;
  align-self: start;
  padding-top: 3px;
}

.source-control-history-node-dot {
  width: 10px;
  height: 10px;
  border: 1.5px solid var(--scm-border);
  border-radius: 999px;
  background: var(--scm-bg-elev);
  transition:
    background 0.16s cubic-bezier(0.23, 1, 0.32, 1),
    border-color 0.16s cubic-bezier(0.23, 1, 0.32, 1),
    box-shadow 0.16s cubic-bezier(0.23, 1, 0.32, 1);
}

.source-control-history-item:hover .source-control-history-node-dot,
.source-control-history-item.is-active .source-control-history-node-dot {
  border-color: var(--scm-accent);
  background: var(--scm-accent);
}

.source-control-history-item.is-active .source-control-history-node-dot {
  box-shadow:
    0 0 0 2px var(--scm-bg-elev),
    0 0 0 4px color-mix(in srgb, var(--scm-accent) 24%, transparent);
}

.source-control-history-body {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 2px;
}

.source-control-history-message {
  margin: 0;
  overflow: hidden;
  color: var(--scm-text);
  font-size: 13px;
  font-weight: 500;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.source-control-history-meta {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 6px;
}

.source-control-history-hash {
  display: inline-flex;
  align-items: center;
  flex: 0 0 auto;
  padding: 1px 7px;
  border: 1px solid var(--scm-border);
  border-radius: 999px;
  background: color-mix(in srgb, var(--scm-bg-hover) 70%, var(--scm-bg-elev));
  color: var(--scm-text-dim);
  font-family: inherit;
  font-size: 10.5px;
  font-weight: 500;
  font-variant-numeric: tabular-nums;
  line-height: 1.35;
}

.source-control-history-author {
  position: relative;
  min-width: 0;
  overflow: hidden;
  padding-left: 8px;
  color: var(--scm-text-faint);
  font-size: 11px;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.source-control-history-author::before {
  content: '·';
  position: absolute;
  left: 0;
  color: var(--scm-text-faint);
}

.source-control-history-time {
  align-self: start;
  color: var(--scm-text-faint);
  font-size: 12px;
  font-variant-numeric: tabular-nums;
  line-height: 1.3;
  padding-top: 1px;
  white-space: nowrap;
}

.source-control-stash-panel {
  margin: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  overflow: hidden;
  padding: 0;
}

.source-control-stash-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 10px;
  padding: 12px 16px 6px;
}

.source-control-stash-heading,
.source-control-stash-summary {
  margin: 0;
}

.source-control-stash-heading {
  color: var(--scm-text);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.01em;
}

.source-control-stash-summary {
  color: var(--scm-text-faint);
  font-size: 12px;
  line-height: 1.45;
  white-space: nowrap;
}

.source-control-stash-toolbar {
  display: flex;
  gap: 8px;
  padding: 0 16px 10px;
}

.source-control-stash-toolbar-btn {
  display: inline-flex;
  min-width: 0;
  align-items: center;
  justify-content: center;
  gap: 6px;
  min-height: 28px;
  padding: 0 10px;
  border-radius: 8px;
  font-size: 12px;
}

.source-control-stash-toolbar-btn svg {
  width: 12px;
  height: 12px;
  flex: 0 0 auto;
  fill: none;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 2;
}

.source-control-stash-note {
  margin: 0;
  padding: 2px 16px 12px;
}

.source-control-stash-list {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 0 10px 10px;
}

.source-control-stash-item {
  border-radius: 10px;
  transition: background 0.12s ease;
}

.source-control-stash-item:hover {
  background: color-mix(in srgb, var(--scm-bg-hover) 74%, transparent);
}

.source-control-stash-item.is-open {
  background: color-mix(in srgb, var(--scm-bg-active) 78%, transparent);
}

.source-control-stash-head {
  display: grid;
  width: 100%;
  grid-template-columns: 28px minmax(0, 1fr) 16px;
  align-items: center;
  gap: 10px;
  border: 0;
  background: transparent;
  padding: 10px;
  text-align: left;
}

.source-control-stash-ref {
  color: var(--scm-text-faint);
  font-family: ui-monospace, 'SF Mono', Menlo, monospace;
  font-size: 11px;
  font-variant-numeric: tabular-nums;
  text-align: center;
}

.source-control-stash-info {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 2px;
}

.source-control-stash-title {
  overflow: hidden;
  color: var(--scm-text);
  font-size: 13px;
  font-weight: 500;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.source-control-stash-meta {
  overflow: hidden;
  color: var(--scm-text-faint);
  font-size: 11.5px;
  line-height: 1.45;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.source-control-stash-chevron {
  width: 14px;
  height: 14px;
  color: var(--scm-text-faint);
  fill: none;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 2;
  transition: transform 0.2s cubic-bezier(0.23, 1, 0.32, 1);
}

.source-control-stash-item.is-open .source-control-stash-chevron {
  transform: rotate(90deg);
}

.source-control-stash-body {
  margin: 0 10px 4px 48px;
  border-top: 1px solid var(--scm-border);
  padding: 8px 0 6px;
}

.source-control-stash-details {
  display: grid;
  gap: 6px;
}

.source-control-stash-detail {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  font-size: 12px;
}

.source-control-stash-detail-label {
  flex: 0 0 36px;
  color: var(--scm-text-faint);
}

.source-control-stash-detail-value {
  min-width: 0;
  overflow: hidden;
  color: var(--scm-text-dim);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.source-control-stash-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 10px;
}

.source-control-stash-action-btn {
  min-height: 26px;
  padding: 0 10px;
  border-radius: 7px;
  font-size: 12px;
}

.source-control-stash-action-btn-danger {
  margin-left: auto;
  color: var(--danger);
}

.source-control-stash-action-btn-danger:hover:not(:disabled) {
  border-color: color-mix(in srgb, var(--danger) 22%, var(--scm-border));
  background: color-mix(in srgb, var(--danger) 10%, transparent);
  color: var(--danger);
}

.source-control-file-list {
  display: flex;
  flex-direction: column;
}

.source-control-file {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  padding: 0 8px;
  border-radius: var(--scm-radius);
  cursor: pointer;
  transition: background 0.12s ease;
}

.source-control-file:hover,
.source-control-file.is-active,
.source-control-file.is-context-target {
  background: var(--scm-bg-hover);
}

.source-control-file-main {
  display: flex;
  min-width: 0;
  flex: 1;
  align-items: center;
  gap: 8px;
  border: 0;
  border-radius: 0;
  background: transparent;
  padding: 5px 0;
  text-align: left;
}

.source-control-file:hover .source-control-file-main,
.source-control-file.is-active .source-control-file-main,
.source-control-file.is-context-target .source-control-file-main {
  background: transparent;
}

.source-control-file-path {
  display: flex;
  min-width: 0;
  flex: 1;
  align-items: baseline;
  gap: 4px;
  overflow: hidden;
}

.source-control-file-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--scm-text);
}

.source-control-file-dir {
  min-width: 0;
  flex-shrink: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 11.5px;
}

.source-control-file-tag {
  width: 16px;
  flex-shrink: 0;
  text-align: center;
  font-family: ui-monospace, 'SF Mono', Menlo, monospace;
  font-size: 11px;
  font-weight: 600;
}

.source-control-file-tag.is-modified {
  color: var(--scm-yellow);
}

.source-control-file-tag.is-added {
  color: var(--scm-green);
}

.source-control-file-tag.is-deleted,
.source-control-file-tag.is-conflicted {
  color: var(--scm-red);
}

.source-control-file-tag.is-renamed {
  color: var(--scm-blue);
}

.source-control-file-tag.is-untracked,
.source-control-file-tag.is-typechange {
  color: var(--scm-accent);
}

.source-control-file-actions {
  display: none;
  align-items: center;
  gap: 2px;
}

.source-control-file:hover .source-control-file-actions,
.source-control-file.is-active .source-control-file-actions {
  display: flex;
}

.source-control-icon-btn {
  display: grid;
  width: 20px;
  height: 20px;
  place-items: center;
  border: 0;
  border-radius: 4px;
  background: transparent;
  color: var(--scm-text-faint);
  cursor: pointer;
  transition:
    background 0.12s ease,
    color 0.12s ease;
}

.source-control-icon-btn:hover:not(:disabled) {
  background: var(--bg-h);
  color: var(--scm-text);
}

@media (max-width: 420px) {
  .source-control-history-item {
    grid-template-columns: 24px minmax(0, 1fr);
    align-items: start;
  }

  .source-control-history-time {
    grid-column: 2;
    justify-self: end;
    margin-top: -2px;
  }

  .source-control-stash-toolbar {
    flex-direction: column;
  }

  .source-control-stash-action-btn-danger {
    margin-left: 0;
  }
}

.source-control-commit {
  margin-top: auto;
  display: flex;
  flex-direction: column;
  gap: 8px;
  background: var(--scm-bg);
  padding: 10px;
}

.source-control-commit-input {
  width: 100%;
  min-height: 60px;
  resize: none;
  border: 1px solid var(--scm-border);
  border-radius: var(--scm-radius);
  background: var(--scm-bg-elev);
  padding: 8px 10px;
  color: var(--scm-text);
  font-family: inherit;
  font-size: 12.5px;
  line-height: 1.5;
  outline: 0;
  transition: border-color 0.15s ease;
}

.source-control-commit-input:focus {
  border-color: var(--settings-accent-soft);
}

.source-control-commit-input::placeholder {
  color: var(--scm-text-faint);
}

.source-control-commit-actions {
  display: flex;
  align-items: center;
  gap: 6px;
}

.source-control-btn {
  border: 1px solid var(--scm-border);
  border-radius: var(--scm-radius);
  background: var(--scm-bg-elev);
  padding: 7px 10px;
  color: var(--scm-text);
  font-family: inherit;
  font-size: 12.5px;
  font-weight: 500;
  cursor: pointer;
  transition:
    background 0.12s ease,
    border-color 0.12s ease;
}

.source-control-btn:hover:not(:disabled) {
  background: var(--scm-bg-hover);
}

.source-control-btn-primary {
  flex: 1;
  border-color: var(--scm-accent);
  background: var(--scm-accent);
  color: var(--primary-foreground);
}

.source-control-btn-primary:hover:not(:disabled) {
  filter: brightness(1.05);
}

.source-control-btn-icon {
  display: grid;
  width: 32px;
  height: 32px;
  flex: 0 0 auto;
  place-items: center;
  padding: 0;
  color: var(--scm-text-dim);
}

.source-control-btn:disabled,
.source-control-icon-btn:disabled,
.source-control-btn-icon:disabled {
  cursor: default;
  opacity: 0.46;
}
