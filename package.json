{
  "name": "calamex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "check:env": "tsx scripts/check-dev-env.ts",
    "check:rolldown": "tsx scripts/check-rolldown-ready.ts",
    "generate:shell-catalog": "tsx scripts/generate-shell-command-catalog.ts",
    "generate:web-picker": "tsx scripts/build-web-element-picker.ts",
    "dev": "pnpm run generate:shell-catalog && pnpm run generate:web-picker && vite --host 0.0.0.0 --port 1420",
    "pretauri:dev": "tsx scripts/check-dev-env.ts",
    "build": "pnpm run generate:shell-catalog && pnpm run generate:web-picker && vue-tsc --noEmit && vite build && node scripts/verify-dist.mjs",
    "preview": "vite preview",
    "format": "biome check --write src/ builtin-agent/src/ scripts/",
    "lint": "biome check src/",
    "lint:ox": "pnpm dlx oxlint@1.68.0 src builtin-agent/src scripts",
    "fix:ox": "pnpm dlx oxlint@1.68.0 --fix src builtin-agent/src scripts",
    "fix": "pnpm format && pnpm fix:ox",
    "lint:all": "pnpm lint && pnpm lint:ox",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:fast": "tsgo --noEmit -p tsconfig.tsgo.json",
    "size-limit": "pnpm run build && size-limit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "guard": "tsx scripts/run-all-guards.ts",
    "tauri": "tsx scripts/run-tauri.ts",
    "tauri:dev": "tsx scripts/run-tauri.ts dev",
    "tauri:build": "pnpm run provision && tsx scripts/run-tauri.ts build && node scripts/verify-bundle.mjs",
    "prepare": "lefthook install",
    "provision": "tsx scripts/provision.ts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.1.0",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "6.43.4",
    "@fancyapps/ui": "^6.1.14",
    "@lucide/vue": "^1.23.0",
    "@medv/finder": "^4.0.2",
    "@replit/codemirror-indentation-markers": "^6.5.3",
    "@shikijs/langs": "^4.3.0",
    "@shikijs/themes": "^4.3.0",
    "@tanstack/query-persist-client-core": "^5.101.2",
    "@tanstack/vue-query": "^5.101.2",
    "@tanstack/vue-virtual": "^3.13.31",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@texel/color": "^1.1.11",
    "@vueuse/core": "^14.3.0",
    "@wasm-fmt/shfmt": "^0.2.7",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "7.0.11",
    "bash-language-server": "^5.6.0",
    "clsx": "^2.1.1",
    "consola": "^3.4.2",
    "idb-keyval": "^6.2.6",
    "katex": "^0.17.0",
    "markstream-vue": "1.0.5-beta.2",
    "motion-v": "2.3.0",
    "pathe": "^2.0.3",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.10.1",
    "shiki": "^4.3.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tokenlens": "^1.3.1",
    "tree-sitter-bash": "^0.25.1",
    "tw-animate-css": "^1.4.0",
    "vue": "3.6.0-beta.16",
    "vue-sonner": "^2.0.9",
    "vue-stick-to-bottom": "^1.0.0",
    "web-tree-sitter": "^0.26.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ai-sdk/codemod": "^4.0.0",
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.2",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@moonshot-ai/kimi-code": "^0.22.0",
    "@playwright/test": "^1.61.1",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.0",
    "@typescript/native-preview": "latest",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/server-renderer": "3.6.0-beta.16",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "@withfig/autocomplete": "^2.692.3",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "knip": "^6.24.0",
    "lefthook": "^2.1.9",
    "rollup-plugin-visualizer": "^7.0.1",
    "shellcheck": "^4.1.0",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.3.2",
    "tree-sitter-cli": "^0.26.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaojianc916/calamex.git"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/xiaojianc916/calamex/issues"
  },
  "homepage": "https://github.com/xiaojianc916/calamex#readme"
}
