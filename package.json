{
  "name": "calamex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "check:env": "tsx scripts/check-dev-env.ts",
    "check:rolldown": "tsx scripts/check-rolldown-ready.ts",
    "generate:shell-catalog": "tsx scripts/generate-shell-command-catalog.ts",
    "generate:web-picker": "tsx scripts/build-web-element-picker.ts",
    "dev": "pnpm run generate:shell-catalog && pnpm run generate:web-picker && vite --host 0.0.0.0 --port 1420",
    "pretauri:dev": "tsx scripts/check-dev-env.ts",
    "build": "pnpm run generate:shell-catalog && pnpm run generate:web-picker && vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "format": "biome check --write src/ agent-sidecar/src/ scripts/",
    "lint": "biome check src/",
    "lint:ox": "pnpm dlx oxlint@1.68.0 src agent-sidecar/src scripts",
    "fix:ox": "pnpm dlx oxlint@1.68.0 --fix src agent-sidecar/src scripts",
    "fix": "pnpm format && pnpm fix:ox",
    "lint:all": "pnpm lint && pnpm lint:ox",
    "typecheck": "vue-tsc --noEmit",
    "size-limit": "pnpm run build && size-limit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "guard": "tsx scripts/run-all-guards.ts",
    "tauri": "tsx scripts/run-tauri.ts",
    "tauri:dev": "tsx scripts/run-tauri.ts dev",
    "tauri:build": "tsx scripts/run-tauri.ts build",
    "prepare": "lefthook install"
  },
