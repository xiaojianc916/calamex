{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/router/**/*.ts",
    "scripts/**/*.{ts,mjs,js}",
    "agent-sidecar/src/server.ts",
    "agent-sidecar/build.mjs"
  ],
  "project": ["src/**/*.{ts,tsx,vue}", "agent-sidecar/src/**/*.{ts,tsx}"],
  "ignore": [
    "src/env.d.ts",
    "src/shims-icons.d.ts",
    "src/types/window.d.ts",
    "src/types/monaco-shims.d.ts",
    "src/**/*.d.ts"
  ],
  "ignoreDependencies": [
    "tailwindcss",
    "tw-animate-css",
    "@commitlint/cli",
    "shellcheck",
    "bash-language-server",
    "@axe-core/playwright",
    "@xterm/addon-search",
    "@xterm/addon-web-links"
  ],
  "ignoreUnresolved": ["~icons/.*"],
  "vite": {
    "config": "vite.config.ts"
  },
  "vitest": {
    "config": [],
    "entry": [
      "src/**/*.{spec,test}.{ts,vue}",
      "src/**/__tests__/**/*.{ts,vue}",
      "src/__tests__/setup.ts"
    ]
  }
}
