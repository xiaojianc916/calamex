{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["src/**/*.{ts,vue,css}", "scripts/**/*.ts", "*.{ts,js,mjs,json}", "!src/bindings/tauri.ts"]
  },
  "formatter": {
    "enabled": true,
    "useEditorconfig": false,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100,
    "attributePosition": "auto",
    "bracketSpacing": true
  },
  "linter": {
    "enabled": true,
    "includes": ["**", "!scripts/**"],
    "rules": {
      "preset": "recommended",
      "correctness": {
        "noUnusedImports": "off",
        "noUnusedVariables": "off"
      },
      "style": {
        "useSingleVarDeclarator": "off",
        "noNonNullAssertion": "off",
        "useVueMultiWordComponentNames": "off"
      },
      "complexity": {
        "noImportantStyles": "off"
      },
      "suspicious": {
        "noExplicitAny": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSameLine": false,
      "quoteProperties": "asNeeded"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "formatter": {
      "quoteStyle": "single",
      "enabled": true
    },
    "linter": {
      "enabled": true
    }
  },
  "overrides": [
    {
      "includes": ["*.json"],
      "formatter": {
        "indentWidth": 2
      }
    },
    {
      "includes": ["src/components/ai-elements/terminal/ansi.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noControlCharactersInRegex": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/constants/shell/command-catalog.ts",
        "src/utils/terminal/shell-completion.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noTemplateCurlyInString": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/styles/editor-tabs.css",
        "src/styles/sidebar-explorer.css",
        "src/styles/sidebar-source-control.css",
        "src/styles/app-shell.css",
        "src/styles/sidebar-source-control-pr.css",
        "src/styles/sidebar-source-control-github-auth.css"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDescendingSpecificity": "off"
          }
        }
      }
    }
  ]
}
