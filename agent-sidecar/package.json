{
  "name": "@xiaojianc/agent-sidecar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "tsx --env-file=.env src/acp/stdio-entry.ts",
    "build": "node build.mjs",
    "start": "node dist/acp/stdio-entry.js",
    "test": "node --import tsx --test --test-reporter=spec \"src/**/*.spec.ts\"",
    "test:tap": "node --import tsx --test --test-reporter=tap \"src/**/*.spec.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:ox": "pnpm --dir .. lint:ox",
    "fix": "pnpm format && pnpm fix:ox"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.29.0",
    "@ai-sdk/deepseek": "^2.0.39",
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@ast-grep/napi": "^0.44.0",
    "@libsql/client": "^0.17.4",
    "@mastra/agent-browser": "^0.4.0",
    "@mastra/core": "^1.45.0",
    "@mastra/libsql": "^1.14.0",
    "@mastra/loggers": "^1.2.0",
    "@mastra/mcp": "^1.11.0",
    "@mastra/memory": "^1.21.0",
    "@mastra/observability": "^1.15.0",
    "@modelcontextprotocol/server-memory": "^2026.1.26",
    "@modelcontextprotocol/server-sequential-thinking": "^2025.12.18",
    "@upstash/context7-mcp": "^3.2.2",
    "eventsource-parser": "^3.1.0",
    "handlebars": "^4.7.9",
    "tavily-mcp": "^0.2.20",
    "tokenlens": "^1.3.1",
    "typescript-language-server": "^5.3.0",
    "undici": "^8.5.0",
    "vscode-jsonrpc": "^9.0.0",
    "vscode-languageserver-protocol": "^3.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "ai": "^6.0.208",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
